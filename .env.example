# IZVPRO - Environment varijable
# Kopiraj ovaj fajl u .env i popuni prave vrednosti
# NIKAD ne commit-uj .env sa pravim kljucevima!

# Supabase konfiguracija
# Nadjis u: Supabase Dashboard -> Project Settings -> API
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Za Vercel deploy:
# Idi na: Vercel Dashboard -> Project -> Settings -> Environment Variables
# Dodaj SUPABASE_URL i SUPABASE_ANON_KEY kao env varijable
# Zatim u index.html dodaj <script> koji injektuje window.__env pre app.js:
#
#   <script>
#     window.__env = {
#       SUPABASE_URL: '%%SUPABASE_URL%%',
#       SUPABASE_ANON_KEY: '%%SUPABASE_ANON_KEY%%'
#     };
#   </script>
#
# Ili koristi Vercel serverless funkciju koja vraca config sa servera.
